# ============================================================
# Operations Dashboard — .env.example
# Kopieren nach .env.local (gitignored) und Werte anpassen.
# ============================================================

# ---- Database ----
ConnectionStrings__Default=Host=localhost;Port=5432;Database=dashboard;Username=dashboard;Password=dev

# ---- JWT ----
# WICHTIG: In Prod durch starken Zufallswert ersetzen (mind. 32 chars).
Jwt__Issuer=nexo-dashboard
Jwt__Audience=nexo-dashboard
Jwt__SigningKey=CHANGE_ME_dev_only_signing_key_min_32_chars_____________
Jwt__AccessTokenMinutes=15
Jwt__RefreshTokenDays=7

# ---- PowerShell ----
PowerShell__ScriptsDirectory=./powershell/scripts
PowerShell__TimeoutSeconds=60

# ---- Logging ----
Serilog__MinimumLevel__Default=Information

# ---- Frontend ----
VITE_API_BASE_URL=/api
