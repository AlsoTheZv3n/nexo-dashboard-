{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.e2e.tsbuildinfo",
    "target": "es2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["@playwright/test", "node"],
    "skipLibCheck": true,
    "strict": true,
    "isolatedModules": false,
    "esModuleInterop": true,
    "noEmit": true,
    "jsx": "react-jsx"
  },
  "include": ["e2e", "playwright.config.ts"]
}
